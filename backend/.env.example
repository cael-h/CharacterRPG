CHARACTERRPG_PROVIDER=mock
CHARACTERRPG_MODEL=gpt-4o-mini

# The backend loads ../.env, ../.env.local, backend/.env, and backend/.env.local.
# It also reads a small provider-key whitelist from ~/.env for Termux convenience.

# OpenAI Responses API
CHARACTERRPG_OPENAI_API_KEY=
# OPENAI_API_KEY= and OPENAI_KEY= are also accepted.
CHARACTERRPG_OPENAI_BASE_URL=https://api.openai.com/v1

# Venice
CHARACTERRPG_VENICE_API_KEY=
# VENICE_API_KEY=, VENICE_AI_API_KEY=, and VENICE_KEY= are also accepted.
CHARACTERRPG_VENICE_BASE_URL=https://api.venice.ai/api/v1
CHARACTERRPG_VENICE_MODEL=aion-labs-aion-2-0

# Generic OpenAI-compatible APIs
CHARACTERRPG_OPENAI_COMPATIBLE_BASE_URL=
CHARACTERRPG_OPENAI_COMPATIBLE_API_KEY=

# Local models
CHARACTERRPG_OLLAMA_BASE_URL=http://localhost:11434
CHARACTERRPG_OLLAMA_MODEL=llama3.1:8b-instruct

# Hugging Face inference endpoint
CHARACTERRPG_HUGGINGFACE_API_KEY=
CHARACTERRPG_HUGGINGFACE_BASE_URL=

CHARACTERRPG_STORAGE_DIR=storage/CharacterRPG_Generated_Files
CHARACTERRPG_TEST_STORAGE_DIR=storage/CharacterRPG_Dev_Tests
